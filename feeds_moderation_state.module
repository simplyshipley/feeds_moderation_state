<?php

/**
 * @file
 * Hooks for the Feeds Moderation State module.
 *
 * Adds per-FeedType configuration for forcing a content moderation state on
 * all entities imported by that feed. Supports bidirectional sync: existing
 * entities can be transitioned to an unpublished state when the source signals
 * unpublished, and to a published state when the source signals published.
 * Settings are stored as third-party settings on the FeedType config entity
 * under the key 'feeds_moderation_state'.
 */

declare(strict_types=1);

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\StringTranslation\TranslatableMarkup;

/**
 * Implements hook_feeds_targets_alter().
 *
 * Removes the 'moderation_state' target from the Feeds mapping UI when this
 * module is enabled on the feed type. This prevents administrators from
 * re-adding a direct moderation_state mapping that would conflict with the
 * module's ModerationStateTarget plugin.
 *
 * @param array<string, \Drupal\feeds\TargetDefinitionInterface> $targets
 *   Available mapping targets, keyed by target ID.
 * @param \Drupal\feeds\FeedTypeInterface $feed_type
 *   The feed type whose mapping targets are being built.
 */
function feeds_moderation_state_feeds_targets_alter(array &$targets, \Drupal\feeds\FeedTypeInterface $feed_type): void {
  $settings = $feed_type->getThirdPartySettings('feeds_moderation_state');

  if (empty($settings['enabled'])) {
    return;
  }

  unset($targets['moderation_state']);
}

/**
 * Implements hook_form_FORM_ID_alter() for feeds_mapping_form.
 *
 * Adds an informational notice to the Feeds mapping page when this module is
 * enabled on the feed type, explaining that the moderation_state target has
 * been removed and that state transitions are managed by this module.
 */
function feeds_moderation_state_form_feeds_mapping_form_alter(array &$form, FormStateInterface $form_state): void {
  // MappingForm is not an EntityForm — the feed type is a named route parameter,
  // not available via getEntity(). Use routeMatch for the named parameter.
  /** @var \Drupal\feeds\FeedTypeInterface|null $feed_type */
  $feed_type = \Drupal::routeMatch()->getParameter('feeds_feed_type');

  if (!$feed_type instanceof \Drupal\feeds\FeedTypeInterface) {
    return;
  }
  $settings = $feed_type->getThirdPartySettings('feeds_moderation_state');

  if (empty($settings['enabled'])) {
    return;
  }

  $form['feeds_moderation_state_notice'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['messages', 'messages--status']],
    '#weight' => -100,
    'message' => [
      '#markup' => t(
        '<strong>Feeds Moderation State is active on this feed type.</strong> ' .
        'The source <em>status</em> field is mapped to the <em>Moderation state</em> target and written directly to the entity. ' .
        '<a href=":url">Configure moderation state settings</a> on the feed type settings page.',
        [':url' => $feed_type->toUrl('edit-form')->toString()]
      ),
    ],
  ];
}

/**
 * Implements hook_feeds_feed_type_presave().
 *
 * Fires whenever a FeedType config entity is saved — including config import,
 * programmatic saves, and form saves. Ensures that any direct mapping to the
 * 'moderation_state' target is converted to 'feeds_moderation_state_value',
 * and that the mapping is present whenever this module is enabled on the feed
 * type.
 *
 * This covers the config import path where the form submit handler does not
 * run. The form submit handler handles the same cleanup for interactive saves
 * and shows an admin messenger notice; this hook provides silent structural
 * enforcement for all other save paths.
 *
 * @param \Drupal\feeds\Entity\FeedType $feed_type
 *   The feed type being saved.
 */
function feeds_moderation_state_feeds_feed_type_presave(\Drupal\feeds\Entity\FeedType $feed_type): void {
  $settings = $feed_type->getThirdPartySettings('feeds_moderation_state');

  if (empty($settings['enabled'])) {
    return;
  }

  _feeds_moderation_state_ensure_value_mapping($feed_type);

  // Remove the legacy no-op passthrough mapping — it is no longer needed
  // because feeds_moderation_state_value already includes 'status' in the
  // Feeds item hash.
  $current = $feed_type->getMappings();
  $has_legacy = !empty(array_filter($current, static fn(array $m): bool => ($m['target'] ?? '') === 'feeds_moderation_state_status'));
  if ($has_legacy) {
    $feed_type->setMappings(_feeds_moderation_state_remove_target_mapping($current, 'feeds_moderation_state_status'));
  }
}

/**
 * Implements hook_help().
 */
function feeds_moderation_state_help(string $route_name, RouteMatchInterface $route_match): string|TranslatableMarkup {
  if ($route_name !== 'help.page.feeds_moderation_state') {
    return '';
  }

  $output = '';
  $output .= '<h2>' . t('About') . '</h2>';
  $output .= '<p>' . t('Forces a configured Content Moderation state on entities imported via Feeds 3.x. Supports bidirectional sync — transitions to an unpublished state when the source signals unpublished, and back to a published state when the source signals published.') . '</p>';
  $output .= '<p>' . t('Only existing entities being updated are affected. New entities created during the initial import use whatever default moderation state the workflow assigns to new content.') . '</p>';

  $output .= '<h2>' . t('Entity type requirements') . '</h2>';
  $output .= '<p>' . t('The entity type must be revisionable and a Content Moderation workflow must be applied to the specific bundle being imported. Taxonomy terms are not revisionable by default and cannot use Content Moderation without additional modules.') . '</p>';

  $output .= '<h2>' . t('Configuration') . '</h2>';
  $output .= '<p>' . t('All settings are per-FeedType. Edit a feed type at <em>Structure &gt; Feed types</em> and expand the <em>Content moderation state</em> fieldset.') . '</p>';
  $output .= '<ol>';
  $output .= '<li>' . t('Check <em>Update moderation state on existing entities when publishing status changes on source</em>.') . '</li>';
  $output .= '<li>' . t('Select the <em>Target moderation state</em> — the state to apply when the source signals unpublished (e.g. <em>draft</em>, <em>archived</em>). Only unpublished states are listed.') . '</li>';
  $output .= '<li>' . t('Set the <em>Unpublished indicator value</em> — the raw source value that means "unpublished". Use <code>0</code> for standard API responses. If <a href=":tamper">Feeds Tamper</a> transforms the status field before it reaches this module (e.g. <code>0</code> &rarr; <em>draft</em>), enter the post-tamper value instead.', [':tamper' => 'https://www.drupal.org/project/feeds_tamper']) . '</li>';
  $output .= '<li>' . t('Optionally enable the <em>Publish direction</em> to also transition entities back to a published state when the source signals published.') . '</li>';
  $output .= '<li>' . t('Save the feed type. The module automatically adds a <em>Moderation state (feeds_moderation_state)</em> mapping so that state changes in the source are detected and applied. You do not need to add this mapping manually.') . '</li>';
  $output .= '</ol>';

  $output .= '<h2>' . t('Do not map directly to moderation_state') . '</h2>';
  $output .= '<p>' . t('Do not add a Feeds field mapping that targets <code>moderation_state</code> directly. This module manages moderation state via the <code>feeds_moderation_state_value</code> target plugin, which writes the value to the entity at mapping time.') . '</p>';

  $output .= '<h2>' . t('Bypass workflow transitions') . '</h2>';
  $output .= '<p>' . t('Checking <em>Bypass workflow transition validation (setSyncing)</em> calls <code>setSyncing(TRUE)</code> on the entity before save, allowing it to jump directly to any state regardless of allowed transitions. Use only for data migration or sync scenarios.') . '</p>';

  return $output;
}

/**
 * Implements hook_form_feeds_feed_type_form_alter().
 *
 * Adds a "Content moderation state" fieldset to the FeedType edit form so
 * that site builders can configure a forced moderation state for entities
 * imported by this feed.
 */
function feeds_moderation_state_form_feeds_feed_type_form_alter(array &$form, FormStateInterface $form_state): void {
  /** @var \Drupal\feeds\Entity\FeedType $feed_type */
  $feed_type = $form_state->getFormObject()->getEntity();

  $settings = $feed_type->getThirdPartySettings('feeds_moderation_state') + [
    'enabled' => FALSE,
    'moderation_state' => '',
    'bypass_transitions' => FALSE,
    'source_unpublished_value' => '0',
    'publish_enabled' => FALSE,
    'publish_moderation_state' => '',
    'source_published_value' => '1',
  ];

  $form['feeds_moderation_state'] = [
    '#type' => 'details',
    '#title' => t('Content moderation state'),
    '#open' => !empty($settings['enabled']),
    '#group' => 'plugin_settings',
    '#tree' => TRUE,
  ];

  $form['feeds_moderation_state']['enabled'] = [
    '#type' => 'checkbox',
    '#title' => t('Update moderation state on <strong>existing</strong> entities when publishing status changes on source'),
    '#description' => t('When enabled, existing entities whose source record has <code>status = 0</code> will be transitioned to the selected moderation state. New entities and records with any other status value are not affected.'),
    '#default_value' => $settings['enabled'],
  ];

  $form['feeds_moderation_state']['moderation_state'] = [
    '#type' => 'select',
    '#title' => t('Target moderation state'),
    '#description' => t('Only unpublished states are listed. Published states must be reached via normal workflow transitions.'),
    '#options' => _feeds_moderation_state_get_state_options(),
    '#empty_option' => t('- Select a state -'),
    '#default_value' => $settings['moderation_state'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
      'required' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['bypass_transitions'] = [
    '#type' => 'checkbox',
    '#title' => t('Bypass workflow transition validation (setSyncing)'),
    '#description' => t('Calls setSyncing(TRUE) on the entity before save, bypassing transition validation. Use only for migration or data-sync scenarios.'),
    '#default_value' => $settings['bypass_transitions'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['source_unpublished_value'] = [
    '#type' => 'textfield',
    '#title' => t('Unpublished indicator value'),
    '#description' => t('The value of the source <code>status</code> field that means "unpublished". Use <code>0</code> for raw API responses. If feeds_tamper transforms the status field (e.g. 0 → <em>draft</em>), enter the post-tamper value here.'),
    '#default_value' => $settings['source_unpublished_value'],
    '#size' => 20,
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['publish_direction'] = [
    '#type' => 'html_tag',
    '#tag' => 'hr',
    '#attributes' => ['style' => 'margin: 1em 0;'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['publish_direction_heading'] = [
    '#type' => 'html_tag',
    '#tag' => 'h4',
    '#value' => t('Publish direction'),
    '#attributes' => ['style' => 'margin: 0 0 0.5em;'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['publish_enabled'] = [
    '#type' => 'checkbox',
    '#title' => t('Transition existing entities to a published state when source status changes to published'),
    '#description' => t('When enabled, existing entities whose source record changes to a published status will be transitioned to the selected moderation state.'),
    '#default_value' => $settings['publish_enabled'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $publish_default = !empty($settings['publish_moderation_state'])
    ? $settings['publish_moderation_state']
    : _feeds_moderation_state_get_default_published_state();

  $form['feeds_moderation_state']['publish_moderation_state'] = [
    '#type' => 'select',
    '#title' => t('Target published moderation state'),
    '#description' => t('The moderation state to apply when the source record becomes published.'),
    '#options' => _feeds_moderation_state_get_state_options(TRUE),
    '#empty_option' => t('- Select a state -'),
    '#default_value' => $publish_default,
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
        ':input[name="feeds_moderation_state[publish_enabled]"]' => ['checked' => TRUE],
      ],
      'required' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
        ':input[name="feeds_moderation_state[publish_enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['source_published_value'] = [
    '#type' => 'textfield',
    '#title' => t('Published indicator value'),
    '#description' => t('The value of the source <code>status</code> field that means "published". Use <code>1</code> for raw API responses. If feeds_tamper transforms the status field (e.g. 1 → <em>published</em>), enter the post-tamper value here.'),
    '#default_value' => $settings['source_published_value'],
    '#size' => 20,
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
        ':input[name="feeds_moderation_state[publish_enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  // Prepend our submit handler so settings are written before the entity save.
  array_unshift($form['actions']['submit']['#submit'], 'feeds_moderation_state_feed_type_form_submit');
}

/**
 * Submit handler for the FeedType form.
 *
 * Persists the moderation state configuration as third-party settings on the
 * FeedType config entity.
 */
function feeds_moderation_state_feed_type_form_submit(array &$form, FormStateInterface $form_state): void {
  /** @var \Drupal\feeds\Entity\FeedType $feed_type */
  $feed_type = $form_state->getFormObject()->getEntity();
  $values = $form_state->getValue('feeds_moderation_state', []);

  $enabled = !empty($values['enabled']);
  $moderation_state = $enabled ? ($values['moderation_state'] ?? '') : '';
  $bypass_transitions = $enabled && !empty($values['bypass_transitions']);

  $source_unpublished_value = $enabled ? ($values['source_unpublished_value'] ?? '0') : '0';

  $publish_enabled = $enabled && !empty($values['publish_enabled']);
  $publish_moderation_state = $publish_enabled ? ($values['publish_moderation_state'] ?? '') : '';
  $source_published_value = $publish_enabled ? ($values['source_published_value'] ?? '1') : '1';

  $feed_type->setThirdPartySetting('feeds_moderation_state', 'enabled', $enabled);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'moderation_state', $moderation_state);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'bypass_transitions', $bypass_transitions);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'source_unpublished_value', $source_unpublished_value);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'publish_enabled', $publish_enabled);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'publish_moderation_state', $publish_moderation_state);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'source_published_value', $source_published_value);

  if ($enabled) {
    $converted = _feeds_moderation_state_ensure_value_mapping($feed_type);
    if ($converted) {
      \Drupal::messenger()->addStatus(t(
        'The <em>moderation_state</em> mapping has been updated to use the supported ' .
        '<em>Moderation state (feeds_moderation_state)</em> target.'
      ));
    }
    return;
  }

  // Module disabled — remove the feeds_moderation_state_value mapping.
  $mappings = $feed_type->getMappings();
  $has_value_target = !empty(array_filter($mappings, static fn(array $m): bool => ($m['target'] ?? '') === 'feeds_moderation_state_value'));
  if ($has_value_target) {
    $feed_type->setMappings(_feeds_moderation_state_remove_target_mapping($mappings, 'feeds_moderation_state_value'));
  }
}

/**
 * Ensures a feeds_moderation_state_value mapping exists on a feed type.
 *
 * Converts any legacy direct 'moderation_state' mapping to the supported
 * 'feeds_moderation_state_value' target. If no value mapping exists at all,
 * auto-injects one mapping the source 'status' field.
 *
 * Called by both the presave hook (silent, covers config import) and the form
 * submit handler (interactive, shows messenger notice on conversion).
 *
 * @param \Drupal\feeds\Entity\FeedType $feed_type
 *   The feed type to update. Mutated in place; caller is responsible for save.
 *
 * @return bool
 *   TRUE if a legacy 'moderation_state' mapping was converted, FALSE otherwise.
 */
function _feeds_moderation_state_ensure_value_mapping(\Drupal\feeds\Entity\FeedType $feed_type): bool {
  $mappings = $feed_type->getMappings();
  $has_value_target = FALSE;
  $converted = FALSE;

  foreach ($mappings as $key => $mapping) {
    $target = $mapping['target'] ?? '';

    // Convert any legacy direct moderation_state mapping to the supported
    // feeds_moderation_state_value target, preserving the source field.
    if ($target === 'moderation_state') {
      $mappings[$key]['target'] = 'feeds_moderation_state_value';
      $has_value_target = TRUE;
      $converted = TRUE;
      continue;
    }

    if ($target === 'feeds_moderation_state_value') {
      $has_value_target = TRUE;
    }
  }

  if ($converted) {
    $feed_type->setMappings(array_values($mappings));
  }

  // If no moderation state mapping exists yet, inject one using the source
  // 'status' field — the standard field name for publish status in most APIs.
  if (!$has_value_target) {
    $feed_type->addMapping([
      'target' => 'feeds_moderation_state_value',
      'map' => ['value' => 'status'],
      'settings' => [],
      'unique' => [],
    ]);
  }

  return $converted;
}

/**
 * Removes all mappings with the given target ID from a mappings array.
 *
 * @param array[] $mappings
 *   The mappings array from FeedType::getMappings().
 * @param string $target
 *   The target ID to remove.
 *
 * @return array[]
 *   The filtered mappings array, re-indexed.
 */
function _feeds_moderation_state_remove_target_mapping(array $mappings, string $target): array {
  return array_values(array_filter($mappings, static function (array $m) use ($target): bool {
    return ($m['target'] ?? '') !== $target;
  }));
}

/**
 * Returns a flat or grouped option list of moderation states.
 *
 * Loads all workflows using the content_moderation plugin and collects states
 * matching the requested published status. Results are grouped by workflow
 * label when more than one workflow is present.
 *
 * @param bool $published
 *   Pass FALSE (default) to return unpublished states; pass TRUE to return
 *   published states.
 *
 * @return array<string, string|array<string, string>>
 *   Options array suitable for a Form API #options element. Single-workflow
 *   sites get a flat list; multi-workflow sites get optgroups keyed by
 *   workflow label.
 */
function _feeds_moderation_state_get_state_options(bool $published = FALSE): array {
  $options = [];

  /** @var \Drupal\workflows\Entity\Workflow[] $workflows */
  $workflows = \Drupal::entityTypeManager()->getStorage('workflow')->loadMultiple();
  foreach ($workflows as $workflow) {
    if ($workflow->getTypePlugin()->getPluginId() !== 'content_moderation') {
      continue;
    }

    $group = [];
    foreach ($workflow->getTypePlugin()->getStates() as $state_id => $state) {
      if ($state->isPublishedState() !== $published) {
        continue;
      }
      $group[$state_id] = $state->label();
    }

    if (!empty($group)) {
      $options[$workflow->label()] = $group;
    }
  }

  // Flatten to a simple list when only one workflow exists.
  if (count($options) === 1) {
    $options = reset($options);
  }

  return $options;
}

/**
 * Returns the first published moderation state ID found across all workflows.
 *
 * Prefers the state with ID 'published' if it exists. Falls back to the first
 * published state encountered. Returns an empty string if no published states
 * are found.
 *
 * @return string
 *   A moderation state ID, or an empty string if none found.
 */
function _feeds_moderation_state_get_default_published_state(): string {
  /** @var \Drupal\workflows\Entity\Workflow[] $workflows */
  $workflows = \Drupal::entityTypeManager()->getStorage('workflow')->loadMultiple();
  $first = '';

  foreach ($workflows as $workflow) {
    if ($workflow->getTypePlugin()->getPluginId() !== 'content_moderation') {
      continue;
    }

    foreach ($workflow->getTypePlugin()->getStates() as $state_id => $state) {
      if (!$state->isPublishedState()) {
        continue;
      }

      if ($state_id === 'published') {
        return 'published';
      }

      if ($first === '') {
        $first = $state_id;
      }
    }
  }

  return $first;
}

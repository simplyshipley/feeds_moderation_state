<?php

/**
 * @file
 * Hooks for the Feeds Moderation State module.
 *
 * Adds per-FeedType configuration for forcing a content moderation state on
 * all entities imported by that feed. Supports bidirectional sync: existing
 * entities can be transitioned to an unpublished state when the source signals
 * unpublished, and to a published state when the source signals published.
 * Settings are stored as third-party settings on the FeedType config entity
 * under the key 'feeds_moderation_state'.
 */

declare(strict_types=1);

use Drupal\Core\Form\FormStateInterface;
use Drupal\workflows\Entity\Workflow;

/**
 * Implements hook_form_feeds_feed_type_form_alter().
 *
 * Adds a "Content moderation state" fieldset to the FeedType edit form so
 * that site builders can configure a forced moderation state for entities
 * imported by this feed.
 */
function feeds_moderation_state_form_feeds_feed_type_form_alter(array &$form, FormStateInterface $form_state): void {
  /** @var \Drupal\feeds\Entity\FeedType $feed_type */
  $feed_type = $form_state->getFormObject()->getEntity();

  $settings = $feed_type->getThirdPartySettings('feeds_moderation_state') + [
    'enabled' => FALSE,
    'moderation_state' => '',
    'bypass_transitions' => FALSE,
    'source_unpublished_value' => '0',
    'publish_enabled' => FALSE,
    'publish_moderation_state' => '',
    'source_published_value' => '1',
  ];

  $form['feeds_moderation_state'] = [
    '#type' => 'details',
    '#title' => t('Content moderation state'),
    '#open' => !empty($settings['enabled']),
    '#group' => 'plugin_settings',
    '#tree' => TRUE,
  ];

  $form['feeds_moderation_state']['enabled'] = [
    '#type' => 'checkbox',
    '#title' => t('Update moderation state on <strong>existing</strong> entities when publishing status changes on source'),
    '#description' => t('When enabled, existing entities whose source record has <code>status = 0</code> will be transitioned to the selected moderation state. New entities and records with any other status value are not affected.'),
    '#default_value' => $settings['enabled'],
  ];

  $form['feeds_moderation_state']['moderation_state'] = [
    '#type' => 'select',
    '#title' => t('Target moderation state'),
    '#description' => t('Only unpublished states are listed. Published states must be reached via normal workflow transitions.'),
    '#options' => _feeds_moderation_state_get_state_options(),
    '#empty_option' => t('- Select a state -'),
    '#default_value' => $settings['moderation_state'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
      'required' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['bypass_transitions'] = [
    '#type' => 'checkbox',
    '#title' => t('Bypass workflow transition validation (setSyncing)'),
    '#description' => t('Calls setSyncing(TRUE) on the entity before save, bypassing transition validation. Use only for migration or data-sync scenarios.'),
    '#default_value' => $settings['bypass_transitions'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['source_unpublished_value'] = [
    '#type' => 'textfield',
    '#title' => t('Unpublished indicator value'),
    '#description' => t('The value of the source <code>status</code> field that means "unpublished". Use <code>0</code> for raw API responses. If feeds_tamper transforms the status field (e.g. 0 → <em>draft</em>), enter the post-tamper value here.'),
    '#default_value' => $settings['source_unpublished_value'],
    '#size' => 20,
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['publish_direction'] = [
    '#type' => 'html_tag',
    '#tag' => 'hr',
    '#attributes' => ['style' => 'margin: 1em 0;'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['publish_direction_heading'] = [
    '#type' => 'html_tag',
    '#tag' => 'h4',
    '#value' => t('Publish direction'),
    '#attributes' => ['style' => 'margin: 0 0 0.5em;'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['publish_enabled'] = [
    '#type' => 'checkbox',
    '#title' => t('Transition existing entities to a published state when source status changes to published'),
    '#description' => t('When enabled, existing entities whose source record changes to a published status will be transitioned to the selected moderation state.'),
    '#default_value' => $settings['publish_enabled'],
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $publish_default = !empty($settings['publish_moderation_state'])
    ? $settings['publish_moderation_state']
    : _feeds_moderation_state_get_default_published_state();

  $form['feeds_moderation_state']['publish_moderation_state'] = [
    '#type' => 'select',
    '#title' => t('Target published moderation state'),
    '#description' => t('The moderation state to apply when the source record becomes published.'),
    '#options' => _feeds_moderation_state_get_state_options(TRUE),
    '#empty_option' => t('- Select a state -'),
    '#default_value' => $publish_default,
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
        ':input[name="feeds_moderation_state[publish_enabled]"]' => ['checked' => TRUE],
      ],
      'required' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
        ':input[name="feeds_moderation_state[publish_enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  $form['feeds_moderation_state']['source_published_value'] = [
    '#type' => 'textfield',
    '#title' => t('Published indicator value'),
    '#description' => t('The value of the source <code>status</code> field that means "published". Use <code>1</code> for raw API responses. If feeds_tamper transforms the status field (e.g. 1 → <em>published</em>), enter the post-tamper value here.'),
    '#default_value' => $settings['source_published_value'],
    '#size' => 20,
    '#states' => [
      'visible' => [
        ':input[name="feeds_moderation_state[enabled]"]' => ['checked' => TRUE],
        ':input[name="feeds_moderation_state[publish_enabled]"]' => ['checked' => TRUE],
      ],
    ],
  ];

  // Prepend our submit handler so settings are written before the entity save.
  array_unshift($form['actions']['submit']['#submit'], 'feeds_moderation_state_feed_type_form_submit');
}

/**
 * Submit handler for the FeedType form.
 *
 * Persists the moderation state configuration as third-party settings on the
 * FeedType config entity.
 */
function feeds_moderation_state_feed_type_form_submit(array &$form, FormStateInterface $form_state): void {
  /** @var \Drupal\feeds\Entity\FeedType $feed_type */
  $feed_type = $form_state->getFormObject()->getEntity();
  $values = $form_state->getValue('feeds_moderation_state', []);

  $enabled = !empty($values['enabled']);
  $moderation_state = $enabled ? ($values['moderation_state'] ?? '') : '';
  $bypass_transitions = $enabled && !empty($values['bypass_transitions']);

  $source_unpublished_value = $enabled ? ($values['source_unpublished_value'] ?? '0') : '0';

  $publish_enabled = $enabled && !empty($values['publish_enabled']);
  $publish_moderation_state = $publish_enabled ? ($values['publish_moderation_state'] ?? '') : '';
  $source_published_value = $publish_enabled ? ($values['source_published_value'] ?? '1') : '1';

  $feed_type->setThirdPartySetting('feeds_moderation_state', 'enabled', $enabled);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'moderation_state', $moderation_state);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'bypass_transitions', $bypass_transitions);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'source_unpublished_value', $source_unpublished_value);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'publish_enabled', $publish_enabled);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'publish_moderation_state', $publish_moderation_state);
  $feed_type->setThirdPartySetting('feeds_moderation_state', 'source_published_value', $source_published_value);

  // Ensure the source 'status' field participates in the Feeds item hash by
  // keeping a mapping to our passthrough target. Feeds only hashes mapped
  // source fields; without this mapping, status-only changes are invisible and
  // PROCESS_ENTITY_PRESAVE never fires for them.
  $mappings = $feed_type->getMappings();
  $has_mapping = FALSE;
  foreach ($mappings as $mapping) {
    if (($mapping['target'] ?? '') === 'feeds_moderation_state_status') {
      $has_mapping = TRUE;
      break;
    }
  }
  if ($enabled && !$has_mapping) {
    $feed_type->addMapping([
      'target' => 'feeds_moderation_state_status',
      'map' => ['value' => 'status'],
      'settings' => [],
      'unique' => [],
    ]);
  }
  elseif (!$enabled && $has_mapping) {
    $mappings = array_values(array_filter($mappings, static function (array $m): bool {
      return ($m['target'] ?? '') !== 'feeds_moderation_state_status';
    }));
    $feed_type->setMappings($mappings);
  }
}

/**
 * Returns a flat or grouped option list of moderation states.
 *
 * Loads all workflows using the content_moderation plugin and collects states
 * matching the requested published status. Results are grouped by workflow
 * label when more than one workflow is present.
 *
 * @param bool $published
 *   Pass FALSE (default) to return unpublished states; pass TRUE to return
 *   published states.
 *
 * @return array<string, string|array<string, string>>
 *   Options array suitable for a Form API #options element. Single-workflow
 *   sites get a flat list; multi-workflow sites get optgroups keyed by
 *   workflow label.
 */
function _feeds_moderation_state_get_state_options(bool $published = FALSE): array {
  $options = [];

  /** @var \Drupal\workflows\Entity\Workflow[] $workflows */
  $workflows = Workflow::loadMultiple();
  foreach ($workflows as $workflow) {
    if ($workflow->get('type') !== 'content_moderation') {
      continue;
    }

    $group = [];
    foreach ($workflow->getTypePlugin()->getStates() as $state_id => $state) {
      if ($state->isPublishedState() !== $published) {
        continue;
      }
      $group[$state_id] = $state->label();
    }

    if (!empty($group)) {
      $options[$workflow->label()] = $group;
    }
  }

  // Flatten to a simple list when only one workflow exists.
  if (count($options) === 1) {
    $options = reset($options);
  }

  return $options;
}

/**
 * Returns the first published moderation state ID found across all workflows.
 *
 * Prefers the state with ID 'published' if it exists. Falls back to the first
 * published state encountered. Returns an empty string if no published states
 * are found.
 *
 * @return string
 *   A moderation state ID, or an empty string if none found.
 */
function _feeds_moderation_state_get_default_published_state(): string {
  /** @var \Drupal\workflows\Entity\Workflow[] $workflows */
  $workflows = Workflow::loadMultiple();
  $first = '';

  foreach ($workflows as $workflow) {
    if ($workflow->get('type') !== 'content_moderation') {
      continue;
    }

    foreach ($workflow->getTypePlugin()->getStates() as $state_id => $state) {
      if (!$state->isPublishedState()) {
        continue;
      }

      if ($state_id === 'published') {
        return 'published';
      }

      if ($first === '') {
        $first = $state_id;
      }
    }
  }

  return $first;
}
